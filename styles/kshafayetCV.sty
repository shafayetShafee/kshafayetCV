%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% kshafayetcv.sty - Modern, minimal, and modular LaTeX style
% for academic CV
%
% This CV is designed for academics, students, and researchers in STEM.
% It prioritizes readability, ease-of-use, clean design, and typography.
% It contains everything you need and nothing you don't.
%
% Version: 0.0.9
% Date: 2026/06/21
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{kshafayetCV}[2026/06/21 Academic CV Style]

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% PACKAGE DEPENDENCIES
% Only essential packages are included for maintainability
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\RequirePackage[T1]{fontenc}                % Font encoding
\RequirePackage{fontawesome5}               % Icons for contact info
\RequirePackage{academicons}                % Icons for contact info (orcid)
\RequirePackage{geometry}                   % Page layout customization
\RequirePackage{sectsty}                    % Section formatting
\RequirePackage{hyperref}                   % Hyperlinks functionality
\RequirePackage[dvipsnames]{xcolor}         % Color support
\RequirePackage{enumitem}                   % List customization
\RequirePackage{titlesec}                   % Section title formatting
\RequirePackage{fancyhdr}                   % Header/footer customization
\RequirePackage{etoolbox}                   % Conditional commands support
\RequirePackage{xparse}
\RequirePackage{xstring}
\RequirePackage{fontspec}
\RequirePackage{kvoptions}

% \RequirePackage[oldstyle,proportional]{ETbb} % ET Book font for elegant typography
% \RequirePackage[sc,osf]{mathpazo}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% GLOBAL FONT CONFIGURATION
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\defaultfontfeatures{Ligatures=TeX}

\setmonofont[
  Path = ../fonts/fira-mono/,
  Scale = MatchLowercase,
  Extension = .ttf,
  UprightFont = FiraMono-Regular,
  ItalicFont = FiraMono-Regular,
  BoldFont = FiraMono-Bold
]{FiraMono-Regular}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% TYPE: ACADEMIC VS INSDUSTRY CONFIGURATION
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\SetupKeyvalOptions{
  family=CV,
  prefix=CV@
}

\DeclareStringOption[academic]{type}
\ProcessKeyvalOptions*

\IfStrEqCase{\CV@type}{
  {academic}{

    %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
    % ACADEMIC FONTS
    %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

    \setmainfont[
      Path = ../fonts/minion-pro/,
      Extension = .otf,
      Renderer = Basic,
      Numbers = {Proportional, OldStyle},
      BoldFont = MinionPro-Bold,
      ItalicFont = MinionPro-It,
      BoldItalicFont = MinionPro-BoldIt,
    ]{MinionPro-Regular}

    \setsansfont[
      Path = ../fonts/cabin/,
      Extension = .ttf,
      Scale = MatchLowercase,
      BoldFont = Cabin-Bold,
      ItalicFont = Cabin-Italic,
      BoldItalicFont = Cabin-BoldItalic,
    ]{Cabin-Regular}

    %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
    % ACADEMIC PAGE LAYOUT
    %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

    \geometry{
      letterpaper,          % Use letter paper size
      left=2.5cm,           % Left margin
      right=2.5cm,          % Right margin
      top=2cm,              % Top margin
      bottom=2.5cm          % Bottom margin
    }

    % Clean typography settings
    \setlength{\parindent}{0pt}     % Remove paragraph indentation
    \setlength{\parskip}{0.2em}     % Set spacing between paragraphs
    \titlespacing*{\section}{0pt}{1.3em}{0.4em}      % Section spacing
    \titlespacing*{\subsection}{0pt}{0.8em}{0.2em}   % Reduced subsection spacing

    % Page numbering and last updated date in footer
    \pagestyle{fancy}
    \fancyhf{}
    \renewcommand{\headrulewidth}{0pt}
    \fancyfoot[L]{\footnotesize Page \thepage}
    \fancyfoot[R]{\footnotesize Last updated: \today}

    %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
    % ACADEMIC TYPOGRAPHY AND STYLING
    %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

    % Section styling with small caps for elegant headers
    \titleformat{\section}{\Large\normalfont\scshape\bfseries}{\thesection}{1em}{}
    \allsectionsfont{\mdseries\scshape}

    % Primary theme color
    \definecolor{primary}{RGB}{83, 39, 115}  % Royal purple

  }
  {industry}{

    %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
    % INDUSTRY FONTS
    %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

    \setmainfont[
        Path = ../fonts/ibm-plex-sans/,
        Extension = .ttf,
        UprightFont = IBMPlexSans-Regular,
        ItalicFont = IBMPlexSans-Italic,
        BoldFont = IBMPlexSans-SemiBold,
        BoldItalicFont = IBMPlexSans-SemiBoldItalic
    ]{IBM Plex Sans}

    \setsansfont[
      Path = ../fonts/ibm-plex-sans/,
      Extension = .ttf,
      UprightFont = IBMPlexSans-Regular,
      ItalicFont = IBMPlexSans-Italic,
      BoldFont = IBMPlexSans-SemiBold,
      BoldItalicFont = IBMPlexSans-SemiBoldItalic,
    ]{IBM Plex Sans}

    %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
    % INDUSTRY PAGE LAYOUT
    %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

    \pagestyle{empty}

    \geometry{
      a4paper,              % Use A4 paper size
      left=1.8cm,           % Left margin
      right=1.8cm,          % Right margin
      top=1.5cm,              % Top margin
      bottom=1.5cm          % Bottom margin
    }

    \setlength{\parindent}{0pt}
    \setlength{\parskip}{0.1em}
    \titlespacing*{\section}{0pt}{1.0em}{0.3em}
    \titlespacing*{\subsection}{0pt}{0.6em}{0.2em}

    %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
    % INDUSTRY TYPOGRAPHY AND STYLING
    %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

    \definecolor{primary}{RGB}{0, 102, 204} % Academic Blue

    \titleformat{\section}{
      \large\normalfont\bfseries
    }{\thesection}{1em}{}[\vspace{-0.8em}\color{primary}\rule{\linewidth}{0.8pt}]

  }
}[
  \PackageError{kshafayetCV}{Unknown CV type '\CV@type'. Use type=academic or type=industry.}{}
]


%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% TYPOGRAPHY AND STYLING
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% Prevent typographical widows and orphans
\clubpenalty=10000
\widowpenalty=10000
\displaywidowpenalty=10000

% Primary theme color - customize by changing RGB values
% \definecolor{primary}{RGB}{153, 51, 102}  % Professional burgundy

% Hyperlink setup with primary color
\hypersetup{
  colorlinks=true,        % Colored links instead of boxes
  urlcolor=primary,       % URL color
  linkcolor=primary,      % Internal link color
  citecolor=primary,      % Citation color
  pdftitle={Curriculum Vitae},
  pdfauthor={},
  pdfcreator={},
  pdfproducer={}
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% HEADER COMMANDS
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% Command for name at top of CV
\newcommand{\cvname}[1]{
  \begin{center}
    {\Huge \textsc{#1}}
  \end{center}
}

% Contact bar with social media and contact info
% Arguments:
%   #1: Email
%   #2: Personal website
%   #3: GitHub username
%   #4: LinkedIn username
%   #5: Google Scholar URL
%   #6: Phone No
%   #7: Location
% Customize your contact bar and use any font awesome (fa) icons from:
% http://mirrors.ibiblio.org/CTAN/fonts/fontawesome5/doc/fontawesome5.pdf
\newcommand{\contactbar}[7]{%
  \small
  \begin{center}
    \setlength{\baselineskip}{1.2\baselineskip}
    \mbox{\faEnvelope\space\href{mailto:#1}{#1}} \enspace
    \mbox{\faGlobe\space\href{https://#2}{#2}} \enspace
    \mbox{\faGithub\space\href{https://github.com/#3}{#3}} \enspace
    \mbox{\faLinkedinIn\space\href{https://linkedin.com/in/#4}{#4}} \enspace
    \mbox{\faGraduationCap\space\href{#5}{Google Scholar}} \enspace
    \mbox{\ttfamily\faPhone*\space#6} \enspace
    \mbox{\faMapMarker*\space#7}
  \end{center}
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% CV/RESUME MODE SWITCH
% Controls which sections are displayed
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\newif\ifcv
\cvtrue  % Default to CV mode (includes all sections)
         % Use \cvfalse to default to resume mode (fewer sections)

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% CONTENT FORMATTING COMMANDS
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% Detailed entry for positions with optional bullet points
% Use for: work experience, education, major projects
% Arguments:
%   #1: [Optional] Bullet points (\item statements)
%   #2: Institution/Organization name
%   #3: Location (city, state/country)
%   #4: Position title or degree
%   #5: Date range
\newcommand{\cvblock}[5][]{%
  \textbf{#2} \hfill #3 \\[1pt]
  #4 \hfill #5
  \par
  \ifx&#1&\else
    \vspace{2pt}
    \begin{itemize}[itemsep=3pt, parsep=0pt, topsep=0pt, leftmargin=*]
      #1
    \end{itemize}
  \fi
}

% Education entry: degree(result) on line 1 w/ location right,
% institute(university) on line 2 w/ year range right
% Arguments:
%   #1: [Optional] Bullet points (\item statements)
%   #2: Degree title
%   #3: [Optional] Result (CGPA, grade, honors, etc.)
%   #4: Institute/Organization name
%   #5: [Optional] Parent institution / university
%   #6: Location (city, state/country)
%   #7: Date range
\NewDocumentCommand{\edublock}{o m o m o m m}{%
  \textbf{#2} \hfill #6 \\[1pt]
  \ifx&#3&
    #4 \hfill #7%
    \ifx&#5&\else \\[1pt] #5\fi
  \else
    {\small\color{gray!60!black}#3} \hfill #7 \\[1pt]
    #4%
    \ifx&#5&\else \\[1pt] #5\fi
  \fi
  \par
  \ifx&#1&\else
    \vspace{2pt}
    \begin{itemize}[itemsep=3pt, parsep=0pt, topsep=0pt, leftmargin=*]
      #1
    \end{itemize}
  \fi
}

% Simple single-line entry for awards, skills, and brief items
% Use for: awards, honors, courses, software, brief accomplishments
% Arguments:
%   #1: Specific achievement/award/item name
%   #2: Granting institution/organization/context
%   #3: Date or date range
\newcommand{\cvitem}[3]{%
  \item #1, \emph{#2} \dotfill \hspace{2pt} \textbf{#3}
}


% \awarditem: award entry with optional context line
% Usage: \awarditem{Award Name}[optional context]
%                  {Issuing Body}{Year}
\NewDocumentCommand{\awarditem}{m o m m}{%
  \item \textbf{#1}, %
  \IfValueT{#2}{{\small\color{gray!70!black} #2, }}%
  \emph{#3} \dotfill \hspace{2pt} \textbf{#4}
  \vspace{5pt}
}



% Configure itemize environment for compact, clean lists
\setlist[itemize]{itemsep=0pt, parsep=0pt, topsep=0pt, leftmargin=*}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% BIBLIOGRAPHY MANAGEMENT
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\RequirePackage[
  style=numeric,
  sorting=ydnt,
  backend=biber,
  giveninits=true,
  maxnames=99
]{biblatex}

% Source - https://tex.stackexchange.com/a/699796
% Posted by Mateen Ulhaq, modified by community.
% Retrieved 2026-06-22, License - CC BY-SA 4.0
\renewcommand*{\mkbibcompletename}[1]{%
  \ifitemannotation{highlight}
    {\textbf{#1}}%
    {#1}%
}

\renewcommand{\mkbibnamefamily}[1]{%
  #1%
  % Author annotations (applied to family names)
  \ifitemannotation{equal}{\textsuperscript{*}}{}%
  \ifitemannotation{corresponding}{$^\dagger$}{}%
}
